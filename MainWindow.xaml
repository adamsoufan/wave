<Window 
    x:Class="Wave.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:media="clr-namespace:System.Windows.Media.Animation;assembly=PresentationFramework"
    Title="Hello WPF" Height="300" Width="400" WindowState="Maximized">
  

    <DockPanel>
        <!-- Side Menu (collapsible) -->
        <StackPanel Name="SideMenu" DockPanel.Dock="Left" Width="200" Background="#2C3E50" >

            <Ellipse Name="ProfileImage" Width="100" Height="100" Stroke="Gray" StrokeThickness="2">
                <Ellipse.Fill>
                    <ImageBrush ImageSource="assets\profile_ph.png" />
                </Ellipse.Fill>
            </Ellipse>


            <Button Content="Profile" Height="40" Margin="10" Click="OpenProfileButton_Click"/>
            <Button Content="Gesture Hub" Height="40" Margin="10" Click="OpenGestureHubButton_Click"/>
            <Button Content="Macro Hub" Height="40" Margin="10" Click="OpenMacroHubButton_Click"/>
            <Button Content="About" Height="40" Margin="10" Click="OpenAboutButton_Click"/>
            <Button Content="Logout" Height="40" Margin="10" Click="LogoutButton_Click"/>
            
            
        </StackPanel>

        <!-- Main Content Area -->
        <Grid Background="White">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- row 0 = title row = defined by title inside -->
                <RowDefinition Height="*"/>     <!-- row 1 = content area = everything else -->
            </Grid.RowDefinitions>


            <!-- Title -->
            <Grid Background="Gray"  Grid.Row="0">
                <TextBlock Text="GESTURES:" HorizontalAlignment="Left" FontSize="24" Margin="10"/>
            </Grid>

            <Grid Grid.Row="1">

                <!-- Sets 3x3 grid-->
                <!-- In the future: implement a smarter grid that resizes based on the amount of gestures-->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                     <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>


                <!-- Create a tile for each grid cell in the 3x3-->
                <StackPanel Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Wave to Close" HorizontalAlignment="Center" FontSize="24" />
                    <Ellipse Name="gestureImage1" Width="200" Height="200" Stroke="Gray" StrokeThickness="2">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="assets\profile_ph.png" />
                        </Ellipse.Fill>
                    </Ellipse>
                    <ToggleButton Name="ToggleButton1" Checked="ToggleButton_Checked" Unchecked="ToggleButton_Unchecked">
                        <ToggleButton.Content>
                            <Image Name="ButtonImage1" Stretch="Fill" Width="200" Height="80" Source="assets\off_ph.png"/>
                        </ToggleButton.Content>
                    </ToggleButton>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Open Youtube" HorizontalAlignment="Center" FontSize="24"/>
                    <Ellipse Name="gestureImage2" Width="200" Height="200" Stroke="Gray" StrokeThickness="2">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="assets\profile_ph.png" />
                        </Ellipse.Fill>
                    </Ellipse>
                    <ToggleButton Name="ToggleButton2" Checked="ToggleButton_Checked" Unchecked="ToggleButton_Unchecked">
                        <ToggleButton.Content>
                            <Image Name="ButtonImage2" Stretch="Fill" Width="200" Height="80" Source="assets\off_ph.png"/>
                        </ToggleButton.Content>
                    </ToggleButton>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Press Left" HorizontalAlignment="Center" FontSize="24" />
                    <Ellipse Name="gestureImage3" Width="200" Height="200" Stroke="Gray" StrokeThickness="2">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="assets\profile_ph.png" />
                        </Ellipse.Fill>
                    </Ellipse>
                    <ToggleButton Name="ToggleButton3" Checked="ToggleButton_Checked" Unchecked="ToggleButton_Unchecked">
                        <ToggleButton.Content>
                            <Image Name="ButtonImage3" Stretch="Fill" Width="200" Height="80" Source="assets\off_ph.png"/>
                        </ToggleButton.Content>
                    </ToggleButton>
                </StackPanel>



            </Grid>

        </Grid>


    </DockPanel>


<!--///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// -->











</Window>
